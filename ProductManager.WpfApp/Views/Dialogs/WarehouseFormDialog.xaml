<Window x:Class="ProductManager.WpfApp.Views.Dialogs.WarehouseFormDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Склад"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <StackPanel Margin="24">

        <TextBlock x:Name="TitleText"
                   Style="{StaticResource PageTitleStyle}"
                   FontSize="18" Margin="0,0,0,20"/>

        <!-- Name -->
        <TextBlock Text="НАЗВА СКЛАДУ" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="4" Background="{StaticResource SurfaceBrush}" Margin="0,0,0,14">
            <TextBox x:Name="NameBox"
                     BorderThickness="0" Padding="10,8"
                     FontSize="14" Background="Transparent"/>
        </Border>

        <!-- Location -->
        <TextBlock Text="ЛОКАЦІЯ" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="4" Background="{StaticResource SurfaceBrush}" Margin="0,0,0,24">
            <ComboBox x:Name="LocationBox"
                      BorderThickness="0" Padding="8,6"
                      FontSize="14" Background="Transparent"/>
        </Border>

        <!-- Validation message -->
        <TextBlock x:Name="ErrorText"
                   Foreground="Red" FontSize="12"
                   Margin="0,0,0,12" Visibility="Collapsed"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Скасувати"
                    Style="{StaticResource OutlineButtonStyle}"
                    Margin="0,0,10,0"
                    Click="CancelClick"/>
            <Button Content="Зберегти"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="SaveClick"/>
        </StackPanel>
    </StackPanel>
</Window>

<Page x:Class="ProductManager.WpfApp.Views.ProductDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Деталі товару">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Back button + title ─────────────────────────────── -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="← Назад"
                        Command="{Binding GoBackCommand}"
                        Style="{StaticResource OutlineButtonStyle}"
                        VerticalAlignment="Center"
                        Margin="0,0,16,0"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding Product.Name}"
                           Style="{StaticResource PageTitleStyle}"
                           VerticalAlignment="Center"
                           Margin="0"/>
            </Grid>

            <!-- ── Category badge row ─────────────────────────────── -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
                <Border Style="{StaticResource BadgeStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🏷 " FontSize="12"/>
                        <TextBlock Text="{Binding Product.Category}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ── Details card ───────────────────────────────────── -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: IDs -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="ID ТОВАРУ" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Text="{Binding Product.Id}"
                                       Style="{StaticResource ValueStyle}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="ID СКЛАДУ" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Text="{Binding Product.WarehouseId}"
                                       Style="{StaticResource ValueStyle}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Divider -->
                    <Separator Grid.Row="1" Background="{StaticResource BorderBrush}"/>

                    <!-- Row 2: Quantity + UnitPrice + TotalValue -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="КІЛЬКІСТЬ" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Style="{StaticResource ValueStyle}" FontSize="22" FontWeight="Bold">
                                <Run Text="{Binding Product.Quantity}"/>
                                <Run Text=" шт"/>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="16,0">
                            <TextBlock Text="ЦІНА ЗА ОДИНИЦЮ" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Style="{StaticResource ValueStyle}" FontSize="22" FontWeight="Bold">
                                <Run Text="{Binding Product.UnitPrice, StringFormat='{}{0:N2}'}"/>
                                <Run Text=" грн"/>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="ЗАГАЛЬНА ВАРТІСТЬ" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Style="{StaticResource ValueStyle}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}">
                                <Run Text="{Binding Product.TotalValue, StringFormat='{}{0:N2}', Mode=OneWay}"/>
                                <Run Text=" грн"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <!-- Divider -->
                    <Separator Grid.Row="3" Background="{StaticResource BorderBrush}"/>

                    <!-- Row 4: Name (full) -->
                    <StackPanel Grid.Row="4">
                        <TextBlock Text="ПОВНА НАЗВА" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Product.Name}"
                                   Style="{StaticResource ValueStyle}"
                                   FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Divider -->
                    <Separator Grid.Row="5" Background="{StaticResource BorderBrush}"/>

                    <!-- Row 6: Category full -->
                    <StackPanel Grid.Row="6">
                        <TextBlock Text="КАТЕГОРІЯ" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Product.Category}"
                                   Style="{StaticResource ValueStyle}"/>
                    </StackPanel>

                    <!-- Divider -->
                    <Separator Grid.Row="7" Background="{StaticResource BorderBrush}"/>

                    <!-- Row 8: Description -->
                    <StackPanel Grid.Row="8">
                        <TextBlock Text="ОПИС / ТЕХНІЧНІ ХАРАКТЕРИСТИКИ"
                                   Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Product.Description}"
                                   Style="{StaticResource ValueStyle}"
                                   Margin="0,6,0,0"
                                   LineHeight="22"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>

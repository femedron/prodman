<Page x:Class="ProductManager.WpfApp.Views.ProductDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Деталі товару">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28,24">

            <!-- Busy overlay -->
            <TextBlock Text="Завантаження…" FontSize="16"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,60,0,0"
                       Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisConverter}}"/>

            <StackPanel Visibility="{Binding IsBusy, Converter={StaticResource InverseBoolToVisConverter}}">

                <!-- Back + title + action buttons -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="← Назад"
                            Command="{Binding GoBackCommand}"
                            Style="{StaticResource OutlineButtonStyle}"
                            VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <TextBlock Grid.Column="1" Text="{Binding Product.Name}"
                               Style="{StaticResource PageTitleStyle}"
                               VerticalAlignment="Center" Margin="0"/>
                    <Button Grid.Column="2" Content="✏ Редагувати"
                            Command="{Binding EditCommand}"
                            Style="{StaticResource OutlineButtonStyle}"
                            VerticalAlignment="Center"/>
                    <Button Grid.Column="4" Content="🗑 Видалити"
                            Command="{Binding DeleteCommand}"
                            Style="{StaticResource OutlineButtonStyle}"
                            VerticalAlignment="Center"/>
                </Grid>

                <!-- Category + warehouse badges -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Border Style="{StaticResource BadgeStyle}" Margin="0,0,8,0">
                        <TextBlock Text="{Binding Product.Category}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                    </Border>
                    <Border Style="{StaticResource BadgeStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏭 " FontSize="12"/>
                            <TextBlock Text="{Binding Product.WarehouseName}"
                                       FontSize="13" Foreground="{StaticResource PrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Detail card -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>

                        <!-- IDs -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="ID ТОВАРУ" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding Product.Id}"
                                           Style="{StaticResource ValueStyle}" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="ID СКЛАДУ" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding Product.WarehouseId}"
                                           Style="{StaticResource ValueStyle}" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>

                        <Separator Background="{StaticResource BorderBrush}" Margin="0,12"/>

                        <!-- Numbers row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="КІЛЬКІСТЬ" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Style="{StaticResource ValueStyle}" FontSize="22" FontWeight="Bold">
                                    <Run Text="{Binding Product.Quantity}"/><Run Text=" шт"/>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="16,0">
                                <TextBlock Text="ЦІНА ЗА ОД." Style="{StaticResource LabelStyle}"/>
                                <TextBlock Style="{StaticResource ValueStyle}" FontSize="22" FontWeight="Bold">
                                    <Run Text="{Binding Product.UnitPrice, StringFormat='{}{0:N2}'}"/>
                                    <Run Text=" грн"/>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="ЗАГАЛЬНА ВАРТІСТЬ" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Style="{StaticResource ValueStyle}" FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}">
                                    <Run Text="{Binding Product.TotalValue, StringFormat='{}{0:N2}'}"/>
                                    <Run Text=" грн"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>

                        <Separator Background="{StaticResource BorderBrush}" Margin="0,12"/>

                        <!-- Description -->
                        <TextBlock Text="ОПИС / ТЕХНІЧНІ ХАРАКТЕРИСТИКИ" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Product.Description}"
                                   Style="{StaticResource ValueStyle}"
                                   Margin="0,6,0,0" LineHeight="22"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>

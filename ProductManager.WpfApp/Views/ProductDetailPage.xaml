<Page x:Class="ProductManager.WpfApp.Views.ProductDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Деталі товару">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Loading state -->
            <TextBlock Grid.Row="0"
                       Text="Завантаження..."
                       FontSize="16" Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,40,0,0"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConverter}}"/>

            <!-- Content — visible only when Product is loaded -->
            <Grid Grid.Row="0"
                  Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Back + title -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="← Назад"
                            Command="{Binding GoBackCommand}"
                            Style="{StaticResource OutlineButtonStyle}"
                            VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Product.Name}"
                               Style="{StaticResource PageTitleStyle}"
                               VerticalAlignment="Center" Margin="0"/>
                </Grid>

                <!-- Category + warehouse badge row -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
                    <Border Style="{StaticResource BadgeStyle}" Margin="0,0,8,0">
                        <TextBlock Text="{Binding Product.Category}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                    </Border>
                    <Border Style="{StaticResource BadgeStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏭 " FontSize="12"/>
                            <TextBlock Text="{Binding Product.WarehouseName}"
                                       FontSize="13" Foreground="{StaticResource PrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Detail card — binds to ProductDetailDto -->
                <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                    <StackPanel>

                        <!-- IDs -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="ID ТОВАРУ" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding Product.Id}"
                                           Style="{StaticResource ValueStyle}" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="ID СКЛАДУ" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding Product.WarehouseId}"
                                           Style="{StaticResource ValueStyle}" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>

                        <Separator Background="{StaticResource BorderBrush}" Margin="0,12"/>

                        <!-- Quantity / UnitPrice / TotalValue -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="КІЛЬКІСТЬ" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Style="{StaticResource ValueStyle}" FontSize="22" FontWeight="Bold">
                                    <Run Text="{Binding Product.Quantity}"/><Run Text=" шт"/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="16,0">
                                <TextBlock Text="ЦІНА ЗА ОДИНИЦЮ" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Style="{StaticResource ValueStyle}" FontSize="22" FontWeight="Bold">
                                    <Run Text="{Binding Product.UnitPrice, StringFormat='{}{0:N2}'}"/><Run Text=" грн"/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="ЗАГАЛЬНА ВАРТІСТЬ" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Style="{StaticResource ValueStyle}"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}">
                                    <Run Text="{Binding Product.TotalValue, StringFormat='{}{0:N2}'}"/><Run Text=" грн"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>

                        <Separator Background="{StaticResource BorderBrush}" Margin="0,12"/>

                        <!-- Description -->
                        <TextBlock Text="ОПИС / ТЕХНІЧНІ ХАРАКТЕРИСТИКИ"
                                   Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Product.Description}"
                                   Style="{StaticResource ValueStyle}"
                                   Margin="0,6,0,0" LineHeight="22"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
